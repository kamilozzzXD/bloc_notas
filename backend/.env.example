# =====================================================
# Variables de entorno requeridas para el backend.
# Copia este archivo como .env o configúralas en tu
# servidor / plataforma de despliegue.
# =====================================================

# Base de datos MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=bloc_notas
DB_USER=tu_usuario_mysql
DB_PASS=tu_contraseña_mysql

# JWT
# Genera una clave de 64+ caracteres en Base64:
#   openssl rand -base64 64
JWT_SECRET=dGhpcy1pcy1hLXZlcnktbG9uZy1zZWNyZXQta2V5LWZvci1ibG9jLW5vdGFzLWFwcA==
JWT_EXPIRATION_MS=86400000

# Puerto del servidor (opcional, por defecto 8080)
PORT=8080
